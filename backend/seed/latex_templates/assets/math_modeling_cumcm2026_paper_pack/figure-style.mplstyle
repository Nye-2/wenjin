figure.dpi: 120
savefig.dpi: 300
savefig.bbox: tight
axes.grid: True
axes.prop_cycle: cycler('color', ['#000000', '#E69F00', '#56B4E9', '#009E73', '#0072B2', '#D55E00', '#CC79A7'])
axes.unicode_minus: False
lines.linewidth: 1.8
lines.markersize: 5
legend.frameon: False
font.sans-serif: Noto Sans CJK SC, SimHei, WenQuanYi Micro Hei, DejaVu Sans
