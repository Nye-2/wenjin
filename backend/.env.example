# AcademiaGPT v2 环境变量配置模板
# 复制此文件为 .env 并填入实际的配置值

# ==================== LLM 模型配置 ====================
# 采用 JSON 数组配置多个模型，支持不同任务使用不同模型
# 字段说明：
#   - id: 模型唯一标识（前端使用）
#   - name: 显示名称
#   - model: 实际调用的模型字符串（如 "deepseek/deepseek-v3"）
#   - desc: 模型描述
#   - temp: 默认温度
#   - api_key: 该模型的 API Key（必选）
#   - base_url: 该模型的 API 基础 URL（必选）
#   - max_tokens: 可选，不设则默认 32768
#   - supports_tools: 可选，是否支持工具调用，默认 false
#   - supports_json_schema: 可选，是否支持 JSON Schema，默认 false
#
# 添加新模型只需在数组中添加新对象，后端会自动识别，前端会自动显示
# 注意：JSON 必须在一行内（python-dotenv 不支持多行）

# LLM 通用参数（可选）
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=120.0
LLM_MAX_RETRIES=3

# 生成模型列表（用于：框架生成、开题报告、论文全文）
LLM_GEN_MODELS=[{"id":"deepseek-v3","name":"DeepSeek V3","model":"deepseek/deepseek-v3","desc":"擅长长文本生成，性价比高","temp":0.7,"api_key":"sk-your-deepseek-key","base_url":"https://api.deepseek.com"}]

# 工具调用模型列表（用于：联网搜索、Agent 任务）
LLM_TOOL_MODELS=[{"id":"qwen3-max","name":"Qwen3 Max","model":"qwen3-max","desc":"通义千问，工具调用能力强","temp":1.0,"api_key":"sk-your-qwen-key","base_url":"https://dashscope.aliyuncs.com/compatible-mode/v1","supports_tools":true}]

# 轻量模型列表（用于：文献元数据提取等低成本任务）
LLM_UTILITY_MODELS=[{"id":"qwen-flash","name":"Qwen Flash","model":"qwen-flash","desc":"快速响应，支持JSON Schema","temp":0.1,"api_key":"sk-your-qwen-key","base_url":"https://dashscope.aliyuncs.com/compatible-mode/v1","supports_json_schema":true}]

# 图片生成模型列表（用于：论文配图生成）
LLM_IMAGE_MODELS=[{"id":"kling-v2-1","name":"Kling V2.1","model":"kling-v2-1","desc":"快手可灵图片生成模型","api_key":"sk-your-kling-key","base_url":"https://api.klingai.com/v1"}]

# ==================== 论文搜索配置 ====================
# Semantic Scholar API Key（推荐配置，不配置会遇到 403 错误）
# 免费获取：https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=
SEMANTIC_SCHOLAR_RATE_LIMIT_DELAY=1.0

# ==================== 上传预处理（Layout Parsing）====================
# 用于 PDF / 图片上传后的结构化解析中间件
LAYOUT_PARSING_ENABLED=false
LAYOUT_PARSING_API_URL=
LAYOUT_PARSING_TOKEN=
LAYOUT_PARSING_TIMEOUT_SECONDS=120
LAYOUT_PARSING_USE_DOC_ORIENTATION_CLASSIFY=false
LAYOUT_PARSING_USE_DOC_UNWARPING=false
LAYOUT_PARSING_USE_CHART_RECOGNITION=false

# ==================== LaTeX 项目配置 ====================
WENJIN_LATEX_DATA_DIR=./.wenjin/latex_projects
WENJIN_LATEX_TEMPLATE_DIR=../../WenjinPrism/templates
WENJIN_LATEX_DEFAULT_COMPILER=xelatex
WENJIN_LATEX_COMPILE_TIMEOUT_SECONDS=300

# ==================== 数据库配置 ====================
# PostgreSQL 连接（支持 pgvector 扩展）
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/academiagpt

# ==================== Redis 配置 ====================
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20

# 缓存 TTL（秒）
REDIS_LLM_CACHE_TTL=3600
REDIS_PDF_CACHE_TTL=7200
REDIS_SESSION_CACHE_TTL=86400

# 速率限制
REDIS_RATE_LIMIT_REQUESTS=120
REDIS_RATE_LIMIT_WINDOW=60
REDIS_GENERATION_LOCK_TTL=600

# ==================== Celery 异步任务配置 ====================
CELERY_ENABLED=false
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_WORKER_CONCURRENCY=2
CELERY_TASK_SOFT_TIME_LIMIT=600
CELERY_TASK_TIME_LIMIT=900

# ==================== JWT 认证配置 ====================
# JWT 密钥（生产环境请使用强随机字符串）
# 生成命令：python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ==================== Sentry 错误监控配置 ====================
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ==================== Prometheus 监控配置 ====================
PROMETHEUS_ENABLED=false

# ==================== SMTP 邮件配置 ====================
# 设置为 false 使用开发模式（验证码固定为 123456）
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_authorization_code
SMTP_USE_TLS=true
SMTP_SENDER_NAME=AcademiaGPT

# 验证码配置
SMTP_CODE_LENGTH=6
SMTP_CODE_TTL=600
SMTP_SEND_INTERVAL=60
SMTP_DAILY_LIMIT=10

# ==================== 应用配置 ====================
# 运行环境
ENVIRONMENT=development
DEBUG=false

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 日志级别
LOG_LEVEL=INFO

# 时区设置
TZ=Asia/Shanghai
