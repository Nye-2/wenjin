# AcademiaGPT v2 环境变量配置模板
# 复制此文件为 .env 并填入实际的配置值

# ==================== LLM 模型配置 ====================
# 运行时模型目录由 DataService model_catalog 管理，可在管理员后台新增/编辑模型。
# LLM_MODELS / LLM_IMAGE_MODELS 仅作为首次 seed/bootstrap 输入和测试夹具，不是生产运行时事实源。
# 采用 JSON 数组配置多个模型，支持不同任务使用不同模型
# 字段说明：
#   - id: 模型唯一标识（前端使用）
#   - name: 显示名称
#   - model: 实际调用的模型字符串（如 "deepseek/deepseek-v3"）
#   - desc: 模型描述
#   - temp: 默认温度
#   - api_key: 该模型的 API Key（必选）
#   - base_url: 该模型的 API 基础 URL（必选）
#   - max_tokens: 可选，不设则默认 32768
#   - supports_tools: 可选，是否支持工具调用，默认 false
#   - supports_json_schema: 可选，是否支持 JSON Schema，默认 false
#
# 添加新模型优先使用管理员后台；修改这里需要重新执行 seed/bootstrap 才会进入 DataService。
# 注意：JSON 必须在一行内（python-dotenv 不支持多行）

# LLM 通用参数（可选）
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=120.0
LLM_MAX_RETRIES=3

# 主生成模型列表（聊天、写作、Agent、工具调用等所有文本任务）
LLM_MODELS=[{"id":"deepseek-v4-pro","name":"DeepSeek V4 Pro","model":"deepseek/deepseek-v4-pro","desc":"DeepSeek V4 Pro，推理与生成能力强","temp":0.3,"api_key":"sk-your-api-key","base_url":"https://api.qnaigc.com/v1","max_tokens":32768,"supports_tools":true}]

# 图片生成模型列表（用于：论文配图生成）
LLM_IMAGE_MODELS=[{"id":"kling-v2-1","name":"Kling V2.1","model":"kling-v2-1","desc":"快手可灵图片生成模型","api_key":"sk-your-kling-key","base_url":"https://api.klingai.com/v1"}]

# Env seed/test helper 的默认模型（生产默认模型以 DataService model_catalog is_default 为准）
LLM_DEFAULT_MODEL=deepseek-v4-pro

# 模型 API Key 加密主密钥。生产必须使用强随机 32-byte key，推荐 base64: 前缀。
# 生成命令：python -c "import base64, secrets; print('base64:' + base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
MODEL_SECRET_KEY=base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
# 也可以改用文件挂载：MODEL_SECRET_KEY_FILE=/run/secrets/wenjin_model_secret_key

# ==================== 论文搜索配置 ====================
# Semantic Scholar API Key（推荐配置，不配置会遇到 403 错误）
# 免费获取：https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=
SEMANTIC_SCHOLAR_RATE_LIMIT_DELAY=1.0

# ==================== 上传预处理（Layout Parsing + Image VLM）====================
# 用于 PDF 上传后的结构化解析中间件（OCR）
LAYOUT_PARSING_ENABLED=false
LAYOUT_PARSING_API_URL=
LAYOUT_PARSING_TOKEN=
LAYOUT_PARSING_TIMEOUT_SECONDS=120
LAYOUT_PARSING_USE_DOC_ORIENTATION_CLASSIFY=false
LAYOUT_PARSING_USE_DOC_UNWARPING=false
LAYOUT_PARSING_USE_CHART_RECOGNITION=false
LAYOUT_PARSING_USE_LAYOUT_DETECTION=true
LAYOUT_PARSING_LAYOUT_THRESHOLD=0.5
LAYOUT_PARSING_LAYOUT_NMS=true
LAYOUT_PARSING_RESTRUCTURE_PAGES=false
LAYOUT_PARSING_MERGE_TABLES=true
LAYOUT_PARSING_RELEVEL_TITLES=true
LAYOUT_PARSING_PRETTIFY_MARKDOWN=true

# 用于图片上传后的 VLM 理解中间件
IMAGE_VLM_ENABLED=false
IMAGE_VLM_API_URL=
IMAGE_VLM_TOKEN=
IMAGE_VLM_MODEL=qwen2.5-vl-7b-instruct
IMAGE_VLM_TIMEOUT_SECONDS=60
IMAGE_VLM_PROMPT=请详细描述这张图片的内容。如果是图表，请说明数据趋势和关键数值；如果是文字截图，请提取主要文字内容；如果是照片，请描述场景和主体。
IMAGE_VLM_MAX_TOKENS=2048
IMAGE_VLM_TEMPERATURE=0.3

# ==================== LaTeX 项目配置 ====================
WENJIN_LATEX_DATA_DIR=./.wenjin/latex_projects
WENJIN_LATEX_TEMPLATE_DIR=../../WenjinPrism/templates
WENJIN_LATEX_DEFAULT_COMPILER=xelatex
WENJIN_LATEX_COMPILE_TIMEOUT_SECONDS=300

# ==================== 数据库配置 ====================
# PostgreSQL 连接（支持 pgvector 扩展）
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/academiagpt

# ==================== DataService 配置 ====================
# Gateway/worker/agent runtime 通过该内部服务访问 canonical data boundary
DATASERVICE_URL=http://localhost:8080
DATASERVICE_INTERNAL_TOKEN=change-me-in-production
DATASERVICE_TIMEOUT_SECONDS=10

# ==================== Redis 配置 ====================
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20
REDIS_STREAM_SOCKET_TIMEOUT_SECONDS=30

# 缓存 TTL（秒）
REDIS_LLM_CACHE_TTL=3600
REDIS_PDF_CACHE_TTL=7200
REDIS_SESSION_CACHE_TTL=86400

# 速率限制
REDIS_RATE_LIMIT_REQUESTS=120
REDIS_RATE_LIMIT_WINDOW=60
REDIS_GENERATION_LOCK_TTL=600

# ==================== Celery 异步任务配置 ====================
CELERY_ENABLED=false
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_WORKER_CONCURRENCY=2
CELERY_WORKER_POOL=solo
CELERY_TASK_SOFT_TIME_LIMIT=600
CELERY_TASK_TIME_LIMIT=900

# Run runtime 配置
RUNTIME_DISCONNECT_CANCEL_GRACE_SECONDS=1.5

# ==================== JWT 认证配置 ====================
# JWT 密钥（生产环境请使用强随机字符串）
# 生成命令：python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ==================== Sentry 错误监控配置 ====================
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ==================== Prometheus 监控配置 ====================
PROMETHEUS_ENABLED=false

# ==================== SMTP 邮件配置 ====================
# 设置为 false 使用开发模式（验证码固定为 123456）
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_authorization_code
SMTP_USE_TLS=true
SMTP_SENDER_NAME=AcademiaGPT

# 验证码配置
SMTP_CODE_LENGTH=6
SMTP_CODE_TTL=600
SMTP_SEND_INTERVAL=60
SMTP_DAILY_LIMIT=10

# ==================== 应用配置 ====================
# 运行环境
ENVIRONMENT=development
DEBUG=false

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 日志级别
LOG_LEVEL=INFO

# 时区设置
TZ=Asia/Shanghai
