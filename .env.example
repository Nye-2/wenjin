# AcademiaGPT v2 - Root Environment Configuration
# For detailed configuration, see backend/.env.example

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/academiagpt

# ============================================
# LLM Configuration
# ============================================
# Option 1: Simple single API key (fallback)
OPENAI_API_KEY=sk-xxx
DEEPSEEK_API_KEY=sk-xxx

# Option 2: Multi-model JSON configuration (recommended)
# See backend/.env.example for full configuration
# LLM_GEN_MODELS=[{"id":"deepseek-v3","model":"deepseek/deepseek-v3","api_key":"sk-xxx","base_url":"https://api.deepseek.com"}]
# LLM_TOOL_MODELS=[{"id":"qwen3-max","model":"qwen3-max","api_key":"sk-xxx","base_url":"https://dashscope.aliyuncs.com/compatible-mode/v1","supports_tools":true}]

# ============================================
# Redis Configuration
# ============================================
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET_KEY=your-super-secret-key-change-in-production

# ============================================
# Optional Services
# ============================================
# Semantic Scholar API (for paper search)
SEMANTIC_SCHOLAR_API_KEY=

# Celery (async tasks)
CELERY_ENABLED=false

# Sentry (error monitoring)
SENTRY_ENABLED=false

# Prometheus (metrics)
PROMETHEUS_ENABLED=false

# SMTP (email verification)
SMTP_ENABLED=false

# ============================================
# Application Settings
# ============================================
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
TZ=Asia/Shanghai
