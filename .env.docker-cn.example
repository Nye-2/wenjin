# Docker build mirrors for mainland China networks
PYTHON_IMAGE=docker.m.daocloud.io/library/python:3.13-slim
NODE_IMAGE=docker.m.daocloud.io/library/node:24-alpine
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
NPM_REGISTRY=https://registry.npmmirror.com
NPM_FALLBACK_REGISTRY=https://registry.npmjs.org
ALPINE_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/alpine
# TeXLive base image (avoid auth-gated mirror defaults)
TEXLIVE_BASE_IMAGE=ubuntu:22.04
# Optional apt mirror for faster package install
# TEXLIVE_APT_MIRROR=https://mirrors.ustc.edu.cn/ubuntu/

# Docker runtime image mirrors for mainland China networks
POSTGRES_IMAGE=docker.m.daocloud.io/pgvector/pgvector:pg16
REDIS_IMAGE=docker.m.daocloud.io/library/redis:8-alpine
NGINX_IMAGE=docker.m.daocloud.io/library/nginx:alpine
PROMETHEUS_IMAGE=docker.m.daocloud.io/prom/prometheus:latest
GRAFANA_IMAGE=docker.m.daocloud.io/grafana/grafana:latest

# Optional runtime values
DB_PASSWORD=postgres
GRAFANA_PASSWORD=admin

# Host absolute project root for nested Docker LaTeX bind-mounts
# Adjust when your local repo path differs.
WENJIN_PROJECT_DIR=/home/cjz/wenjin
